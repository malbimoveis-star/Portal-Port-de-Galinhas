# Porta do servidor backend
PORT=3000

# Ambiente
NODE_ENV=development

# Segredo usado para assinar tokens JWT do painel do comerciante
JWT_SECRET=troque_este_valor_por_um_segredo_forte

# Caminho do arquivo do banco SQLite (relativo a pasta backend em dev local;
# em producao no Railway, aponte para um caminho absoluto dentro do Volume
# persistente, ex: DB_PATH=/data/portal.db)
DB_PATH=./data/portal.db

# Mercado Pago - Access Token de TESTE (sandbox). Obtenha em:
# https://www.mercadopago.com.br/developers/panel/app
# NUNCA commitar o token real. Use apenas em .env local / variaveis de ambiente do provedor de deploy.
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-00000000000000000000000000000000-000000000

# URL publica do frontend (usada para montar back_urls do Mercado Pago)
# Backend e frontend agora rodam juntos na mesma porta/URL.
FRONTEND_URL=http://localhost:3000

# URL publica do backend (usada para montar notification_url do webhook)
BACKEND_URL=http://localhost:3000

# Dias de degustacao gratuita para novos comerciantes
DIAS_DEGUSTACAO=5

# Credenciais do painel administrativo (/admin) - troque antes de ir para producao
ADMIN_USER=admin
ADMIN_PASS=admin123
